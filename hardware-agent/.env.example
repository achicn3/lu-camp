# hardware-agent 環境變數範例（複製成 .env 後填入實際值；.env 不入 repo）
#
# 裝置 IP 一律由此處提供，程式碼內不寫死（CLAUDE.md：絕不可 hardcode 裝置 IP）。
# 建議在路由器以 DHCP 依「裝置 MAC」綁定固定 IP；日後 IP 變更時只需改這一處。

# 後端店家抬頭來源（收據/明細聯抬頭，見 agent/store_client.py）
AGENT_BACKEND_URL=http://localhost:8000
# AGENT_SERVICE_TOKEN=  # 後端服務對服務 token（如後端要求）

# --- 裝置連線（兩台皆網路，A 級統一 TCP 9100 探測；見 docs/15、ADR-011）---

# EPSON TM-T82III 收據/發票機（網路版）
AGENT_EPSON_HOST=192.168.0.42
# AGENT_EPSON_PORT=9100        # 預設 9100（RAW/JetDirect）

# Brother QL-810W 標籤/條碼機（網路版）— 請填入實機 IP（待現場確認，勿臆造）
AGENT_BROTHER_HOST=
# AGENT_BROTHER_PORT=9100      # 預設 9100

# A 級 TCP 探測逾時（秒，兩台共用；避免輪詢卡住 /devices/status）
# AGENT_DEVICE_PROBE_TIMEOUT=2.0
