# ── 環境變數範本（入庫；只放佔位值，禁止填真實金鑰/密碼）──
# 複製成 .env 後填本機開發值；.env 不入庫（見 .gitignore）。
# 正式環境的金鑰/密碼由部署環境或 KMS 注入，不寫進 repo。

# ── PostgreSQL（docker-compose 開發 DB 會讀這幾個）──
POSTGRES_USER=lucamp
POSTGRES_PASSWORD=change-me
POSTGRES_DB=lucamp

# ── 後端 ──
# 應用程式連線字串（asyncpg）。host/port 對應 compose 綁定的 127.0.0.1:5432。
DATABASE_URL=postgresql+asyncpg://lucamp:change-me@127.0.0.1:5432/lucamp
# development | test | production
APP_ENV=development

# ── 金鑰（目前尚未被程式使用；T3/T4 導入加密/認證時才接進 core/config）──
# JWT 簽章金鑰
SECRET_KEY=change-me
# PII 欄位層級加密金鑰（national_id 等）；T3 決定確切格式（如 base64 32-byte）
PII_ENC_KEY=change-me
# national_id blind-index 用的 HMAC 金鑰
HMAC_KEY=change-me
