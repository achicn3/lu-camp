# ── 環境變數範本（入庫；只放佔位值，禁止填真實金鑰/密碼）──
# 複製成 .env 後填本機開發值；.env 不入庫（見 .gitignore）。
# 正式環境的金鑰/密碼由部署環境或 KMS 注入，不寫進 repo。

# ── PostgreSQL（docker-compose 開發 DB 會讀這幾個）──
POSTGRES_USER=lucamp
POSTGRES_PASSWORD=change-me
POSTGRES_DB=lucamp

# ── 後端 ──
# 應用程式連線字串（asyncpg）。host/port 對應 compose 綁定的 127.0.0.1:5432。
DATABASE_URL=postgresql+asyncpg://lucamp:change-me@127.0.0.1:5432/lucamp
# development | test | production
APP_ENV=development

# ── 金鑰（禁止填真值入 repo；正式環境由部署/KMS 注入）──
# JWT 簽章金鑰（HS256；建議 >= 32 bytes 高熵）
SECRET_KEY=change-me-high-entropy
# PII 欄位加密金鑰：base64 of 32 bytes（AES-256-GCM）
#   產生：openssl rand -base64 32
PII_ENC_KEY=change-me-base64-32-bytes
# national_id blind-index 用 HMAC 金鑰（任意高熵字串）
#   產生：openssl rand -hex 32
HMAC_KEY=change-me-high-entropy
