{
  "components": {
    "schemas": {
      "ContactCreate": {
        "description": "建立聯絡人輸入。收購/寄售對象（SELLER/CONSIGNOR）必填 national_id。",
        "properties": {
          "default_carrier_id": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Default Carrier Id"
          },
          "default_carrier_type": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Default Carrier Type"
          },
          "member_points": {
            "default": 0,
            "title": "Member Points",
            "type": "integer"
          },
          "name": {
            "minLength": 1,
            "title": "Name",
            "type": "string"
          },
          "national_id": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "National Id"
          },
          "phone": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Phone"
          },
          "roles": {
            "items": {
              "$ref": "#/components/schemas/ContactRole"
            },
            "title": "Roles",
            "type": "array"
          },
          "source_note": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Source Note"
          }
        },
        "required": [
          "name"
        ],
        "title": "ContactCreate",
        "type": "object"
      },
      "ContactLookupRequest": {
        "description": "以 national_id 精確查重（放 body，避免 national_id 進入 URL / access log）。",
        "properties": {
          "national_id": {
            "minLength": 1,
            "title": "National Id",
            "type": "string"
          }
        },
        "required": [
          "national_id"
        ],
        "title": "ContactLookupRequest",
        "type": "object"
      },
      "ContactNationalIdRead": {
        "description": "MANAGER 解密查看的回應（明文，僅此端點回傳）。",
        "properties": {
          "national_id": {
            "title": "National Id",
            "type": "string"
          }
        },
        "required": [
          "national_id"
        ],
        "title": "ContactNationalIdRead",
        "type": "object"
      },
      "ContactRead": {
        "description": "聯絡人輸出：national_id 一律遮罩，不回明文。",
        "properties": {
          "default_carrier_id": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Default Carrier Id"
          },
          "default_carrier_type": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Default Carrier Type"
          },
          "has_national_id": {
            "title": "Has National Id",
            "type": "boolean"
          },
          "id": {
            "title": "Id",
            "type": "integer"
          },
          "member_points": {
            "title": "Member Points",
            "type": "integer"
          },
          "name": {
            "title": "Name",
            "type": "string"
          },
          "national_id_masked": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "National Id Masked"
          },
          "phone": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Phone"
          },
          "roles": {
            "items": {
              "type": "string"
            },
            "title": "Roles",
            "type": "array"
          },
          "source_note": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Source Note"
          },
          "store_id": {
            "title": "Store Id",
            "type": "integer"
          }
        },
        "required": [
          "id",
          "store_id",
          "name",
          "phone",
          "roles",
          "member_points",
          "default_carrier_type",
          "default_carrier_id",
          "source_note",
          "national_id_masked",
          "has_national_id"
        ],
        "title": "ContactRead",
        "type": "object"
      },
      "ContactRole": {
        "description": "聯絡人角色（統一主檔可同時具備多重角色）。",
        "enum": [
          "MEMBER",
          "SELLER",
          "CONSIGNOR"
        ],
        "title": "ContactRole",
        "type": "string"
      },
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "title": "Detail",
            "type": "array"
          }
        },
        "title": "HTTPValidationError",
        "type": "object"
      },
      "HealthResponse": {
        "description": "`/health` 回應。",
        "properties": {
          "status": {
            "title": "Status",
            "type": "string"
          }
        },
        "required": [
          "status"
        ],
        "title": "HealthResponse",
        "type": "object"
      },
      "ValidationError": {
        "properties": {
          "ctx": {
            "title": "Context",
            "type": "object"
          },
          "input": {
            "title": "Input"
          },
          "loc": {
            "items": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "integer"
                }
              ]
            },
            "title": "Location",
            "type": "array"
          },
          "msg": {
            "title": "Message",
            "type": "string"
          },
          "type": {
            "title": "Error Type",
            "type": "string"
          }
        },
        "required": [
          "loc",
          "msg",
          "type"
        ],
        "title": "ValidationError",
        "type": "object"
      }
    },
    "securitySchemes": {
      "HTTPBearer": {
        "scheme": "bearer",
        "type": "http"
      }
    }
  },
  "info": {
    "title": "lu-camp API",
    "version": "0.1.0"
  },
  "openapi": "3.1.0",
  "paths": {
    "/api/v1/contacts": {
      "get": {
        "operationId": "listContacts",
        "parameters": [
          {
            "in": "query",
            "name": "role",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "$ref": "#/components/schemas/ContactRole"
                },
                {
                  "type": "null"
                }
              ],
              "title": "Role"
            }
          },
          {
            "in": "query",
            "name": "q",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "title": "Q"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "items": {
                    "$ref": "#/components/schemas/ContactRead"
                  },
                  "title": "Response Listcontacts",
                  "type": "array"
                }
              }
            },
            "description": "Successful Response"
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            },
            "description": "Validation Error"
          }
        },
        "security": [
          {
            "HTTPBearer": []
          }
        ],
        "summary": "List Contacts",
        "tags": [
          "contacts"
        ]
      },
      "post": {
        "operationId": "createContact",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ContactCreate"
              }
            }
          },
          "required": true
        },
        "responses": {
          "201": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ContactRead"
                }
              }
            },
            "description": "Successful Response"
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            },
            "description": "Validation Error"
          }
        },
        "security": [
          {
            "HTTPBearer": []
          }
        ],
        "summary": "Create Contact",
        "tags": [
          "contacts"
        ]
      }
    },
    "/api/v1/contacts/lookup": {
      "post": {
        "operationId": "lookupContact",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ContactLookupRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "anyOf": [
                    {
                      "$ref": "#/components/schemas/ContactRead"
                    },
                    {
                      "type": "null"
                    }
                  ],
                  "title": "Response Lookupcontact"
                }
              }
            },
            "description": "Successful Response"
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            },
            "description": "Validation Error"
          }
        },
        "security": [
          {
            "HTTPBearer": []
          }
        ],
        "summary": "Lookup Contact",
        "tags": [
          "contacts"
        ]
      }
    },
    "/api/v1/contacts/{contact_id}": {
      "get": {
        "operationId": "getContact",
        "parameters": [
          {
            "in": "path",
            "name": "contact_id",
            "required": true,
            "schema": {
              "title": "Contact Id",
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ContactRead"
                }
              }
            },
            "description": "Successful Response"
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            },
            "description": "Validation Error"
          }
        },
        "security": [
          {
            "HTTPBearer": []
          }
        ],
        "summary": "Get Contact",
        "tags": [
          "contacts"
        ]
      }
    },
    "/api/v1/contacts/{contact_id}/national-id": {
      "get": {
        "operationId": "revealContactNationalId",
        "parameters": [
          {
            "in": "path",
            "name": "contact_id",
            "required": true,
            "schema": {
              "title": "Contact Id",
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ContactNationalIdRead"
                }
              }
            },
            "description": "Successful Response"
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            },
            "description": "Validation Error"
          }
        },
        "security": [
          {
            "HTTPBearer": []
          }
        ],
        "summary": "Reveal National Id",
        "tags": [
          "contacts"
        ]
      }
    },
    "/api/v1/health": {
      "get": {
        "operationId": "getHealth",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HealthResponse"
                }
              }
            },
            "description": "Successful Response"
          }
        },
        "summary": "Health",
        "tags": [
          "system"
        ]
      }
    }
  }
}
